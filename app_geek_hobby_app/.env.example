# Environment variables for GeekHobby App
# Copy this file to .env and replace the placeholder values with your actual API keys


# ---GAMES DATA SOURCES---
# RAWG API Key / REST Endpoint
# Free for personal use, commercial use requires a paid plan when exceeding usage limits(fine for now)
# Get your key at: https://rawg.io/apidocs
RAWG_API_KEY=your_rawg_api_key_here

# ---MOVIE DATA SOURCES---
# OMDB API Key / REST Endpoint
# Free for personal use within rate limits / requires paid plan for commercial use (£1/month)
# Get your key at: https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=your_omdb_api_key_here

# ---ANIME DATA SOURCES---
# Anilist API/ GraphQL Endpoint no key required
# Free for personal and commercial use within rate limits
# No API key needed - uses public GraphQL endpoint
